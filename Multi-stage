pipeline {
  agent none

  stages {
    stage('Build & Check') {
      parallel {

        stage('Back-end') {
          agent {
            docker {
              image 'maven:3.9-eclipse-temurin-21'
              reuseNode true
            }
          }
          options {
            retry(2)
          }
          steps {
            checkout scm
            sh 'mvn --version'
          }
        }

        stage('Front-end') {
          agent {
            docker {
              image 'node:18-alpine'
              reuseNode true
            }
          }
          options {
            retry(2)
          }
          steps {
            checkout scm
            sh 'node --version'
            sh 'npm --version'
          }
        }

      }
    }
  }
}
